{
  "name": "skillshub",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise skills/prompts/agents artifact management platform",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r exec rm -rf dist",
    "cli": "pnpm --filter @skillshub/cli start",
    "server": "pnpm --filter @skillshub/server start",
    "web": "pnpm --filter @skillshub/web dev",
    "web:build": "pnpm --filter @skillshub/web build",
    "admin": "pnpm --filter @skillshub/admin dev",
    "admin:build": "pnpm --filter @skillshub/admin build",
    "lint": "echo \"(configure linter here)\"",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.7.0"
}
