{
  "name": "@skillos/storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').mkdirSync('dist/db',{recursive:true});require('fs').copyFileSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@skillos/config": "workspace:*",
    "@skillos/core": "workspace:*",
    "@skillos/utils": "workspace:*",
    "better-sqlite3": "^11.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10"
  }
}
